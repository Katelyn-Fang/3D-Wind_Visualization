#!/bin/bash -l
#$ -N wind_dir_cpu
#$ -j y
#$ -l h_rt=12:00:00
#$ -pe omp 4
#$ -t 1-6

set -euo pipefail
PROJECT_DIR="/projectnb/YOUR_PROJECT/YOUR_BU_ID/wind-ml-pipeline"
module load miniconda
module load academic-ml/spring-2026
conda activate spring-2026-pyt
cd "$PROJECT_DIR"
export OMP_NUM_THREADS="$NSLOTS"
export MKL_NUM_THREADS="$NSLOTS"
export OPENBLAS_NUM_THREADS="$NSLOTS"

ROW=$(awk -F',' 'NR>1 && $1=="1" && $4=="cpu" {print}' configs/direction_experiments.csv | sed -n "${SGE_TASK_ID}p")
IFS=',' read -r ENABLED EXPERIMENT MODEL RESOURCE DIRECTION_MODEL DIRECTION_TARGET YAW_TRANSFORM DIR_MIN DIR_LOSS DIR_NORM ATT_UNIT N_EST MIN_LEAF MAX_DEPTH MAX_FEATURES SEQ HIDDEN LAYERS HEADS EPOCHS BATCH LR PATIENCE <<< "$ROW"
OUT="results/scc/direction_experiments/cpu/${SGE_TASK_ID}_${EXPERIMENT}"
mkdir -p "$OUT"
CMD=(python src/train_wind_model.py
  --data data/full_standardized.csv
  --split-manifest data/full_split_manifest.csv
  --output-dir "$OUT"
  --model "$MODEL"
  --n-estimators "$N_EST"
  --min-samples-leaf "$MIN_LEAF"
  --max-depth "$MAX_DEPTH"
  --max-features "$MAX_FEATURES"
  --learning-rate "$LR"
  # Fixed at 60 (the longest sequence in this grid) so every direction run
  # reports common_* metrics over the identical endpoint subset.
  --comparison-sequence-length 60
  --direction-target "$DIRECTION_TARGET"
  --direction-min-speed "$DIR_MIN"
  --direction-loss-weight "$DIR_LOSS"
  --direction-norm-weight "$DIR_NORM"
  --attitude-angle-unit "$ATT_UNIT"
  --n-jobs "$NSLOTS"
  --feature-importance)
if [[ -n "$DIRECTION_MODEL" ]]; then CMD+=(--direction-model "$DIRECTION_MODEL"); fi
if [[ -n "$YAW_TRANSFORM" ]]; then CMD+=(--yaw-transform "$YAW_TRANSFORM"); fi
"${CMD[@]}"
